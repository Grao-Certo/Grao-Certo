CREATE TABLE
    historico_estoque (
        idHistorico INT PRIMARY KEY AUTO_INCREMENT,
        fkSilo INT,
        volume_anterior DECIMAL(10, 2),
        volume_novo DECIMAL(10, 2),
        diferenca DECIMAL(10, 2),
        dataHora DATETIME DEFAULT CURRENT_TIMESTAMP,
        CONSTRAINT chFkSilo FOREIGN KEY (fkSilo) REFERENCES silo (idSilo)
    );

CREATE TABLE
    sensor (
        idSensor INT PRIMARY KEY AUTO_INCREMENT,
        identificacao_sensor VARCHAR(45) UNIQUE,
        status_sensor VARCHAR(20),
        data_instalacao DATE,
        fkSilo INT NOT NULL,
        CONSTRAINT chStatusSensor CHECK (
            status_sensor IN ('ativo', 'inativo', 'manutencao', 'instalacao')
        ),
        CONSTRAINT chFkSilo FOREIGN KEY (fkSilo) REFERENCES silo (idSilo)
    );

ALTER TABLE dado
