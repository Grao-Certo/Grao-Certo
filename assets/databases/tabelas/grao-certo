-- Criar Database
CREATE DATABASE graoCerto;

-- Utilizar Database
USE graoCerto;

-- Criar tabela usuario
CREATE TABLE
    usuario (
        idUsuario INT PRIMARY KEY AUTO_INCREMENT,
        nome VARCHAR(60) NOT NULL,
        senha CHAR(60), -- Como ainda não aprendemos sobre Hash e criptografia de senha, mantemos este campo como exemplo.
        email VARCHAR(60) UNIQUE NOT NULL,
        tipo_pessoa CHAR(2),
        CONSTRAINT CHK_TIPO CHECK (tipo_pessoa IN ('PF', 'PJ')),
        documento VARCHAR(14) UNIQUE NOT NULL, -- CPF ou CNPJ, a depender do dado em tipo_pessoa
        CEP CHAR(8),
        quantidade_silos INT
    );

-- Criar tabela silo
/*
OBS: Cada silo precisa de tipos diferentes de dados para gerar o volume total final
Silo Trincheira — Formato: Retangular (Prisma Retangular) — Volume: Comprimento × Largura × Altura
Silo Cilíndrico — Formato: Cilindro — Volume: π · r² · h
Silo Cilíndrico com Teto Cônico — Formato: Cilindro + Cone — Volume: π · r² · h + (1/3) · π · r² · h(cone)
 */
CREATE TABLE
    silo (
        idSilo INT PRIMARY KEY AUTO_INCREMENT,
        tipoSilo VARCHAR(30),
        CONSTRAINT CHK_SILO CHECK (
            tipoSilo IN (
                'Trincheira',
                'Cilindrico',
                'Cilindrico com Teto Cônico'
            )
        ),
        alturaTotal_silo DECIMAL(5, 2),
        comprimento_silo DECIMAL(5, 2),
        largura_silo DECIMAL(5, 2),
        raio DECIMAL(5, 2),
        alturaCone_silo DECIMAL(5, 2),
        volumeMaximo_silo DECIMAL(10, 2),
        fkUsuario INT,
        CONSTRAINT chFkUsuario FOREIGN KEY (fkUsuario) REFERENCES usuario (idUsuario)
    );

-- Criar tabela dado
CREATE TABLE
    dado (
        idDado INT PRIMARY KEY AUTO_INCREMENT,
        distanciaSuperficie DECIMAL(5, 2),
        volumeEstimado_silo DECIMAL(10, 2),
        dataHora DATETIME DEFAULT CURRENT_TIMESTAMP,
        fkSilo INT NOT NULL,
        CONSTRAINT chFkSilo FOREIGN KEY (fkSilo) REFERENCES silo (idSilo)
    );

