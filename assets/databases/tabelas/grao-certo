-- Exemplos de SELECT
-- Quantidade de silos de um usuário
SELECT nome, quantidade_silos
FROM usuario
WHERE nome = 'Rafael Moura';

-- Volume atual de um silo
SELECT volumeEstimado_silo AS volume_atual
FROM dado
WHERE fkSilo = 1;

-- Capacidade máxima de um silo
SELECT volumeMaximo_silo AS capacidade_maxima
FROM silo
WHERE idSilo = 1;

-- Melhor visualização dos Usuários:
SELECT
nome AS nome_usuario,
email AS email_usuario,
CONCAT(tipo_pessoa, ' - ', documento) AS identificacao,
CONCAT('CEP: ', CEP) AS cep_formatado,
quantidade_silos AS qtd_silos_cadastrada,
CASE
WHEN tipo_pessoa = 'PF' THEN 'Pessoa Física'
WHEN tipo_pessoa = 'PJ' THEN 'Pessoa Jurídica'
ELSE 'Não informado'
END AS tipo_descricao
FROM usuario
ORDER BY nome;

-- Verificação do percentual dos silos do tipo Trincheira:
SELECT
silo.idSilo AS silo,
(dado.volumeEstimado_silo / silo.volumeMaximo_silo) * 100 AS percentual
FROM silo, dado
WHERE silo.tipoSilo = 'Trincheira' AND dado.fkSilo = silo.idSilo
ORDER BY percentual DESC;


-- Sprint 2

CREATE DATABASE grao;
USE grao; 

-- Lista quais silos cada usuário tem.
SELECT 
    usuario.nome AS 'usuário',
    silo.idSilo,
    silo.tipoSilo,
    silo.data_instalacao
FROM usuario
	JOIN silo  
		ON usuario.idUsuario = silo.fkUsuario;
        

-- ver dados coletados por silo        
SELECT
    silo.idSilo,
    silo.tipoSilo,
    dado.volumeEstimado_silo,
    dado.dataHora
FROM silo
	JOIN dado
		ON silo.idSilo = dado.fkSilo;
	

-- Mostrar percentual de ocupação do silo

SELECT
    silo.idSilo,
    silo.tipoSilo,
    dado.volumeEstimado_silo,
    silo.volumeMaximo_silo,
    (dado.volumeEstimado_silo / silo.volumeMaximo_silo) * 100 AS percentual
FROM silo
	JOIN dado
		ON dado.fkSilo = silo.idSilo;



















