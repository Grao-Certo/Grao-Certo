    volumeEstimado_silo AS volume_atual
FROM
    dado
WHERE
    fkSilo = 1;

-- Capacidade máxima de um silo
SELECT
    volumeMaximo_silo AS capacidade_maxima
FROM
    silo
WHERE
    idSilo = 1;

-- Melhor visualização dos Usuários:
SELECT
    nome AS nome_usuario,
    email AS email_usuario,
    CONCAT (tipo_pessoa, ' - ', documento) AS identificacao,
    CONCAT ('CEP: ', CEP) AS cep_formatado,
    quantidade_silos AS qtd_silos_cadastrada,
    CASE
        WHEN tipo_pessoa = 'PF' THEN 'Pessoa Física'
        WHEN tipo_pessoa = 'PJ' THEN 'Pessoa Jurídica'
        ELSE 'Não informado'
    END AS tipo_descricao
FROM
    usuario
ORDER BY
    nome;

-- Verificação do percentual dos silos do tipo Trincheira:
SELECT
    silo.idSilo AS silo,
    (dado.volumeEstimado_silo / silo.volumeMaximo_silo) * 100 AS percentual
FROM
    JOIN dado ON dado.fkSilo = silo.idSilo
WHERE
    silo.tipoSilo = 'Trincheira'
    AND dado.fkSilo = silo.idSilo
ORDER BY
    percentual DESC;

